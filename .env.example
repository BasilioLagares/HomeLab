# Safe values for validating the public War Room Compose example.
# Copy to a local `.env`; never add the resulting file to Git.

WARROOM_BIND=127.0.0.1
WARROOM_PORT=8090
WARROOM_MANUALS_DIR=../../docs/manuals
WARROOM_STATE_DIR=../../state
WARROOM_RUNTIME_DIR=../../runtime/war-room
WARROOM_PROXY_NETWORK=homelab_proxy

# War Room application configuration. All hosts are non-routable examples.
WARROOM_TIMEZONE=UTC
WARROOM_SERVICE_WARROOM_URL=https://warroom.example.invalid
WARROOM_SERVICE_WARROOM_PROBE_URL=https://warroom.example.invalid
WARROOM_SERVICE_HOMEPAGE_URL=https://homepage.example.invalid
WARROOM_SERVICE_HOMEPAGE_PROBE_URL=https://homepage.example.invalid
WARROOM_SERVICE_KUMA_URL=https://status.example.invalid
WARROOM_SERVICE_KUMA_PROBE_URL=https://status.example.invalid
WARROOM_SERVICE_PHP_URL=https://demo.example.invalid
WARROOM_SERVICE_PHP_PROBE_URL=https://demo.example.invalid
WARROOM_SERVICE_CUSTOM_ID=custom
WARROOM_SERVICE_CUSTOM_NAME=Custom Service
WARROOM_SERVICE_CUSTOM_URL=https://custom.example.invalid
WARROOM_SERVICE_CUSTOM_PROBE_URL=https://custom.example.invalid
WARROOM_SERVICE_ADMINER_URL=https://database.example.invalid
WARROOM_SERVICE_ADMINER_PROBE_URL=https://database.example.invalid
