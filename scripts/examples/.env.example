# Safe placeholders only. Copy to a local .env file that is never committed.

DRY_RUN=1

# MariaDB backup template
DB_CONTAINER=example_db
DB_NAME=example_database
DB_USER=example_user
DB_PASSWORD_FILE=/path/to/local/secret-file-not-versioned
DB_PASSWORD_ENV=
BACKUP_DIR=/path/to/local/backups
BACKUP_PREFIX=example-backup

# Persistent data backup template
STACK_DIR=/path/to/local/stack
SERVICE_NAME=example_service
DATA_VOLUME=example_data_volume
CONFIRM_STOP=no

# Stack update template
STACK_NAME=example-stack
REQUIRE_CLEAN_GIT=1
REQUIRE_BACKUP_CONFIRMATION=1
