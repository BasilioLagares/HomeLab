# HomeLab safe Git ignore policy
#
# Conservative by default: keep secrets, runtime data, backups and generated
# artefacts out of Git. Review every newly tracked file manually before adding.

# --- Git / local tooling metadata ---
.git/
.agents/
.codex/
_local_sensitive_archive/

# --- Environment files and local overrides ---
.env
.env.*
*.env
*.env.*
!.env.example
!.env.sample
*.local
*.local.*
*.override
*.override.*

# --- Secrets, credentials and tokens ---
scripts/.secrets/
scripts/**/*.secret
scripts/**/*.password
*secret*
*secrets*
*credential*
*credentials*
*token*
*tokens*
*apikey*
*api-key*
*api_key*
*passwd*
*password*
*basic_auth*
*basicauth*
*.htpasswd
*.htdigest
id_rsa*
id_dsa*
id_ecdsa*
id_ed25519*
known_hosts
authorized_keys

# --- Private keys, certificates and local CAs ---
*.key
*.pem
*.p12
*.pfx
*.jks
*.keystore
*.crt
*.cer
*.csr
*.srl
*.ca
certs/
**/certs/
**/*ca*/
**/*CA*/

# --- WireGuard and VPN material ---
platform/wireguard/
**/wireguard/
**/wg0.conf
**/wg-*.conf
**/*wireguard*
**/*WireGuard*
**/*wg-private*
**/*wg-public*
**/*preshared*

# --- Backups, dumps and archives ---
backups/
**/backups/
backup/
**/backup/
*.bak
*.bak-*
*.backup
*.backup-*
*.old
*.orig
*.save
*.sql
*.dump
*.dmp
*.tar
*.tgz
*.tar.gz
*.tar.bz2
*.tar.xz
*.zip
*.7z
*.rar
*.gz
*.bz2
*.xz

# --- Databases and persistent application data ---
apps/
data/
**/data/
state/
**/state/
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
*.sqlite-shm
*.sqlite-wal
*.mdb
*.rdb
*.aof

# --- Container runtime, volumes and generated state ---
runtime/
**/runtime/
volumes/
**/volumes/
storage/
**/storage/
uploads/
**/uploads/
media/
**/media/
downloads/
**/downloads/

# --- Logs, caches and temporary files ---
logs/
**/logs/
*.log
*.log.*
.cache/
**/.cache/
cache/
**/cache/
tmp/
**/tmp/
temp/
**/temp/
*.tmp
*.temp
*.pid
*.sock
*.lock
*.swp
*.swo
*~

# --- System and editor generated files ---
.DS_Store
Thumbs.db
desktop.ini
.Trash-*/
.vscode/
.idea/
*.code-workspace
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Caddy sensitive generated material ---
proxy/
proxy/*.crt
proxy/*.key
proxy/*.pem
proxy/*.p12
proxy/*.pfx
proxy/*basic_auth*
proxy/*htpasswd*
proxy/*credential*
proxy/*secret*
proxy/*token*

# --- Compose files with real secrets must stay ignored unless sanitized ---
stacks/
**/docker-compose.override.yml
**/docker-compose.override.yaml
**/compose.override.yml
**/compose.override.yaml
**/*secret*.yml
**/*secret*.yaml
**/*credential*.yml
**/*credential*.yaml

# --- Reviewable documentation and code allow-list ---
!docs/
!docs/**
!README.md
!**/README.md
!*.md
!**/*.md

!platform/
!platform/war-room/
!platform/war-room/**
platform/war-room/**/*.log
platform/war-room/**/runtime/
platform/war-room/**/cache/
platform/war-room/**/tmp/
platform/war-room/**/.env
platform/war-room/**/*.env
platform/war-room/**/*.bak
platform/war-room/**/*.bak-*
platform/war-room/**/*.tar
platform/war-room/**/*.tgz
platform/war-room/**/*.tar.gz
platform/war-room/**/*.zip
platform/war-room/**/*.7z
platform/war-room/**/*.db
platform/war-room/**/*.sqlite
platform/war-room/**/*.sqlite3

!scripts/
!scripts/**/*.sh
!tools/
!tools/**/*.sh
tools/backups/

# Runtime state stays private. Only explicitly sanitized examples may be added.
!state/
!state/*.example.json

# Final safety overrides. Keep these ignored until sanitized examples exist.
runtime/
apps/
proxy/
stacks/
tools/backups/

# --- Public v0.1 boundary ---
# The public snapshot contains curated manuals, not the local project journal.
/docs/*
!/docs/manuals/
!/docs/manuals/**

# Host-specific operational scripts stay local; publish only scripts/examples/.
/scripts/*.sh

# Real deployment and operational task state stay local. Their sanitized
# counterparts are docker-compose.example.yml and state/*.example.json.
/platform/war-room/docker-compose.yml
/platform/war-room/public/assets/war-room-bg.png
/state/*.json
!/state/*.example.json

# --- Final deny rules (must remain after every allow-list) ---
# Prevent later documentation/code allow-lists from re-including sensitive names.
**/*secret*
**/*secrets*
**/*credential*
**/*credentials*
**/*token*
**/*tokens*
**/*apikey*
**/*api-key*
**/*api_key*
**/*passwd*
**/*password*
**/*basic_auth*
**/*basicauth*
**/*.htpasswd
**/*.htdigest
**/id_rsa*
**/id_dsa*
**/id_ecdsa*
**/id_ed25519*
**/known_hosts
**/authorized_keys
**/*.key
**/*.pem
**/*.p12
**/*.pfx
**/*.jks
**/*.keystore
**/*.crt
**/*.cer
**/*.csr
**/*.srl
**/*.sql
**/*.dump
**/*.dmp
**/*.db
**/*.sqlite
**/*.sqlite3
